# ─────────────────────────────────────────────────────────────
# Eve Research App — environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only key — NEVER expose to the browser. Used for admin/import jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# REQUIRED Supabase dashboard setting for password reset / auth links.
# Set these in: Supabase → Authentication → URL Configuration.
# If these are missing, password-reset links break.
#   Site URL:       https://eve-research.com
#   Redirect URLs:  https://eve-research.com/**
# (For local dev also add: http://localhost:3000/**)
# ─────────────────────────────────────────────────────────────

# Public base URL of the app (used for building booking links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Messaging ──
# Email via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM="Eve Research <hello@eve-research.com>"

# ── Phase 4+: Google Calendar (not needed yet) ──
# Service-account or OAuth credentials for the Calendar API
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_LAUREN_ID=
GOOGLE_CALENDAR_LISA_ID=

# ── Phase 3+: Jotform intake webhook ──
JOTFORM_API_KEY=
JOTFORM_WEBHOOK_SECRET=
